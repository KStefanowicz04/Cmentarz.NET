@model IEnumerable<ProjektCmentarz.Models.Grave>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.GravePlot)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.GraveDeceased)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.BurialDepth)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.GravePlot.Id)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.GraveDeceased.FirstName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.BurialDepth.Depth)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
