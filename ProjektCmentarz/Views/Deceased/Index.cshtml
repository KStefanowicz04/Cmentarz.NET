@model IEnumerable<ProjektCmentarz.Models.Deceased>

@{
    ViewData["Title"] = "Wyszukiwarka Zmarłych";
}

<div class="container mt-4">
    <h1 class="mb-4 text-center">Wyszukiwarka Zmarłych</h1>

    <div class="card shadow-sm mb-4">
        <div class="card-body bg-light">
            <form asp-action="Index" method="get" class="row g-3">
                <div class="col-md-4">
                    <label class="form-label fw-bold">Imię</label>
                    <input type="text" name="searchFirstName" value="@ViewData["CurrentFirstName"]" class="form-control" placeholder="Szukaj imienia..." />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold">Nazwisko</label>
                    <input type="text" name="searchSurname" value="@ViewData["CurrentSurname"]" class="form-control" placeholder="Szukaj nazwiska..." />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold">Data zgonu</label>
                    <input type="date" name="searchDate" value="@ViewData["CurrentDate"]" class="form-control" />
                </div>
                <div class="col-md-1 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">Szukaj</button>
                </div>
            </form>
            <div class="mt-2">
                <a asp-action="Index" class="text-secondary small">Wyczyść filtry</a>
            </div>
        </div>
    </div>

    <p>
        <a asp-action="Create" class="btn btn-success">Dodaj Nowego</a>
    </p>

    <table class="table table-striped table-hover border">
        <thead class="table-dark">
            <tr>
                <th>Imię</th>
                <th>Nazwisko</th>
                <th>Data Urodzenia</th>
                <th>Data Zgonu</th>
                <th>Akcje</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.FirstName</td>
                    <td>@item.Surname</td>
                    <td>@item.BirthDate.ToShortDateString()</td>
                    <td>@item.DeathDate.ToShortDateString()</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edytuj</a>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white">Szczegóły</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Usuń</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>